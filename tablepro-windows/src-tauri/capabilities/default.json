{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main TablePro window",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-title",
    "core:app:allow-version",
    "core:app:allow-name",
    "dialog:default"
  ]
}
