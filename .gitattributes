# Auto detect text files and perform LF normalization
* text=auto

# Rust source
*.rs text eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf

# Markdown
*.md text eol=lf
*.mdx text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell
*.ps1 text eol=crlf

# Configuration files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.pdf binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Installers
*.msi binary
*.exe binary
